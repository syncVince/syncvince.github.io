---
const { title, frontmatter, description, image } = Astro.props;

// Titolo dinamico
const pageTitle = title || frontmatter?.title || "Portfolio Riparazioni";

// Descrizione dinamica (usa quella dell'articolo, o una di default per la Home)
const pageDesc = description || frontmatter?.description || "Documentazione tecnica, teardown e riparazioni hardware.";

// Immagine dinamica per l'anteprima (usa quella dell'articolo, o una di default)
const pageImage = image || frontmatter?.image || "/favicon.png"; 

const formatDate = (dateString: string | number | Date) => {
  if (!dateString) return '';
  return new Date(dateString).toLocaleDateString('it-IT');
};

const tags = frontmatter?.tags || [];
---

<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{pageTitle}</title>

    <!-- Meta tags per SEO e Open Graph (anteprime social) -->
    <meta name="description" content={pageDesc} />
    
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:image" content={new URL(pageImage, Astro.url)} />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={pageTitle} />
    <meta property="twitter:description" content={pageDesc} />
    <meta property="twitter:image" content={new URL(pageImage, Astro.url)} />
    
    
    <script is:inline>
      function getTheme() {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return 'auto';
      }
      function applyTheme(theme) {
        if (theme === 'dark' || (theme === 'auto' && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      }
      applyTheme(getTheme());
    </script>

    <style is:global>
      /* Variabili light mode */
      :root {
        --bg-color: #f8f9fa;
        --text-color: #212529;
        --accent-color: #FF6700;
        --border-color: #dee2e6;
        --code-bg: #e9ecef;
        --card-bg: #ffffff;
        --font-mono: 'Consolas', 'Monaco', 'Courier New', monospace;
        --font-sans: system-ui, -apple-system, sans-serif;
      }

      /* Variabili dark mode */
      html.dark {
        --bg-color: #0d1117;
        --text-color: #c9d1d9;
        --accent-color: #FF6700;
        --border-color: #30363d;
        --code-bg: #161b22;
        --card-bg: #0d1117;
      }

      body {
        font-family: var(--font-sans);
        background-color: var(--bg-color);
        color: var(--text-color);
        line-height: 1.7;
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
        font-size: 1.05rem;
        transition: background-color 0.3s ease, color 0.3s ease;
      }

      h1, h2, h3, nav { font-family: var(--font-mono); font-weight: normal; }
      h1 { border-bottom: 2px solid var(--accent-color); padding-bottom: 0.5rem; display: inline-block; }

      nav {
        display: flex; gap: 1.5rem; align-items: center; padding-bottom: 1.5rem;
        border-bottom: 1px dashed var(--border-color); margin-bottom: 2.5rem;
        flex-wrap: wrap;
      }
      nav a { color: var(--text-color); text-decoration: none; text-transform: uppercase; font-size: 0.9rem; letter-spacing: 0.05em; }
      nav a:hover { color: var(--accent-color); }
      
      /* Stile del toggle switcher */
      .theme-select {
        margin-left: auto;
        padding: 0.3rem 0.5rem;
        background: var(--card-bg);
        color: var(--text-color);
        border: 1px solid var(--border-color);
        border-radius: 4px;
        font-family: var(--font-mono);
        font-size: 0.8rem;
        cursor: pointer;
      }

      a { color: var(--accent-color); text-decoration: none; }
      a:hover { text-decoration: underline; }
      img, video, iframe { max-width: 100%; height: auto; border-radius: 4px; border: 1px solid var(--border-color); margin: 1.5rem 0; }
      pre, code { background-color: var(--code-bg); font-family: var(--font-mono); font-size: 0.9em; border-radius: 4px; }
      code { padding: 0.2em 0.4em; }
      pre { padding: 1rem; overflow-x: auto; border: 1px solid var(--border-color); }

      .block-list { list-style: none; padding: 0; }
      .block-item { margin-bottom: 1rem; background-color: var(--card-bg); border: 1px solid var(--border-color); transition: border-color 0.2s ease, transform 0.2s ease; }
      .block-item:hover { border-color: var(--accent-color); transform: translateX(4px); }
      .block-item a { display: block; padding: 1rem; color: var(--text-color); text-decoration: none; }
      .block-title { font-family: var(--font-mono); font-size: 1.1rem; display: block; margin-bottom: 0.5rem; }
      
      .meta-container { display: flex; flex-wrap: wrap; gap: 1rem; font-size: 0.85rem; font-family: var(--font-mono); margin-top: -1rem; margin-bottom: 2rem; color: #888; align-items: center; }
      .meta-item { display: flex; align-items: center; gap: 0.4rem; }
      .meta-item svg { width: 16px; height: 16px; fill: currentColor; }
      
      /* Stile per i tag */
      .tags-container { display: flex; gap: 0.5rem; flex-wrap: wrap; }
      .tag { background: var(--code-bg); color: var(--text-color); border: 1px solid var(--border-color); padding: 0.1rem 0.5rem; border-radius: 12px; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; }
    </style>
  </head>
  <body>
    <!-- Navigazione principale (navbar) -->
    <nav> 
      <a href="/">Home</a>
      <a href="/progetti">Progetti</a>
      <a href="/riparazioni">Riparazioni</a>
      
      <select id="theme-selector" class="theme-select" aria-label="Cambia tema">
        <option value="auto">Tema: Auto</option>
        <option value="light">Tema: Chiaro</option>
        <option value="dark">Tema: Scuro</option>
      </select>
    </nav>
    <main>
      {(frontmatter?.date || frontmatter?.repairDate) && (
        <div class="meta-container">
          
          {/* 1. DATA ESECUZIONE (calendario) */}
          {frontmatter?.repairDate && (
            <div class="meta-item" title="Periodo di esecuzione">
              <svg viewBox="0 0 24 24"><path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM7 10h5v5H7v-5z"/></svg>
              {frontmatter.repairDate}
            </div>
          )}

          {/* 2. DATA STESURA (penna) */}
          {frontmatter?.date && (
            <div class="meta-item" title="Data di stesura articolo">
              <svg viewBox="0 0 24 24"><path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/></svg>
              {formatDate(frontmatter.date)}
            </div>
          )}
          
          {/* 3. DATA AGGIORNAMENTO (sync) */}
          {frontmatter?.updatedDate && (
            <div class="meta-item" title="Ultimo aggiornamento">
              <svg viewBox="0 0 24 24"><path d="M21 10.12h-6.78l2.74-2.82c-2.73-2.7-7.15-2.8-9.88-.1-2.73 2.71-2.73 7.08 0 9.79s7.15 2.71 9.88 0C18.32 15.65 19 14.08 19 12.1h2c0 2.5-1.06 4.84-2.98 6.64-3.51 3.23-9.15 3.23-12.66 0-3.52-3.23-3.52-8.48 0-11.72 3.51-3.23 9.15-3.23 12.66 0l2.98-3V10.12zM12.5 8v4.25l3.5 2.08-.72 1.21L11 13V8h1.5z"/></svg>
              {formatDate(frontmatter.updatedDate)}
            </div>
          )}

          {tags.length > 0 && (
            <div class="tags-container">
              {tags.map((tag: string) => <span class="tag">{tag}</span>)}
            </div>
          )}
        </div>
      )}
      <slot />
    </main>

    <script>
      const select = document.getElementById('theme-selector') as HTMLSelectElement;
      
      // Imposta il valore iniziale del selettore
      const currentTheme = localStorage.getItem('theme') || 'auto';
      select.value = currentTheme;

      select.addEventListener('change', (e) => {
        const theme = (e.target as HTMLSelectElement).value;
        localStorage.setItem('theme', theme);
        
        if (theme === 'dark' || (theme === 'auto' && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      });

      // Ascolta i cambiamenti di sistema se è su "auto"
      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
        if (localStorage.getItem('theme') === 'auto' || !localStorage.getItem('theme')) {
          if (e.matches) {
            document.documentElement.classList.add('dark');
          } else {
            document.documentElement.classList.remove('dark');
          }
        }
      });
    </script>
  </body>
</html>