  <div class="cta-section">
    <!-- 
    <h2>Ultimi aggiornamenti...</h2> 
    <p>Documentazione tecnica e log dei progetti.</p>
    -->
    
    <ul class="block-list">
      <li class="block-item">
        <a href="/riparazioni">
          <span class="block-title">Vai all'archivio riparazioni &rarr;</span>
          <span style="font-size: 0.9rem; color: #888;">Alcune delle riparazioni e teardown che ho svolto negli ultimi anni.</span>
        </a>
      </li>
    </ul>
    
    <!--
    <ul class="block-list">
      <li class="block-item">
        <a href="/progetti">
          <span class="block-title">Vai all'archivio progetti &rarr;</span>
          <span style="font-size: 0.9rem; color: #888;">Alcuni dei progetti più recenti.</span>
        </a>
      </li>
    </ul>
    -->
  </div>

  <style>
    .hero-section {
      margin-bottom: 3rem;
    }
    .social-links {
      display: flex;
      flex-wrap: wrap;
      gap: 1.5rem;
      margin-top: 2rem;
    }
    .social-links a {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      color: var(--text-color);
      font-family: var(--font-mono);
      font-size: 0.9rem;
      padding: 0.5rem 0.8rem;
      border: 1px solid var(--border-color);
      border-radius: 4px;
      transition: all 0.2s ease;
      background: var(--card-bg);
    }
    .social-links a:hover {
      border-color: var(--accent-color);
      color: var(--accent-color);
    }
    .social-links svg {
      width: 20px;
      height: 20px;
      fill: currentColor;
    }
    .cta-section {
      margin-top: 3rem;
      border-top: 1px dashed var(--border-color);
      padding-top: 2rem;
    }
  </style>
</Layout>